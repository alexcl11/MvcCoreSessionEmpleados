@model List<Empleado>

<h1>Empleados Almacenados Session V4</h1>

<p>
    <a asp-controller="Empleados" asp-action="SessionEmpleadosV4">Volver a empleados V4</a>
</p>

@if (Model != null)
{
    <table class="table table-bordered">
        <thead>
        <th>Id Empleado</th>
        <th>Apellido</th>
        <th>Oficio</th>
        <th>Salario</th>
        <th>Id Departamento</th>
        </thead>
        <tbody>
            @foreach (Empleado empleado in Model)
            {
                <tr>
                    <td>@empleado.IdEmpleado</td>
                    <td>@empleado.Apellido</td>
                    <td>@empleado.Oficio</td>
                    <td>@empleado.Salario</td>
                    <td>@empleado.IdDepartamento</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <h2>No tiene empleados almacenados en Session</h2>
}