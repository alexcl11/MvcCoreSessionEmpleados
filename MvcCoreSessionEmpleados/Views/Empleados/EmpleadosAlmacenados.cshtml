@{
    List < Empleado > empleados = Context.Session.GetObject<List<Empleado>>("EMPLEADOS");
}

<h1>Empleados Almacenados Session</h1>

<p>
    <a asp-controller="Empleados" asp-action="EmpleadosSession">Volver a empleados</a>
</p>

@if (Context.Session.GetString("EMPLEADOS") != null)
{
    <table class="table table-bordered">
        <thead>
            <th>Id Empleado</th>
            <th>Apellido</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th>Id Departamento</th>
        </thead>
        <tbody>
            @foreach (Empleado empleado in empleados)
            {
                <tr>
                    <td>@empleado.IdEmpleado</td>
                    <td>@empleado.Apellido</td>
                    <td>@empleado.Oficio</td>
                    <td>@empleado.Salario</td>
                    <td>@empleado.IdDepartamento</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <h2>No tiene empleados almacenados en Session</h2>
}